{
  // ========== SCM (Source Control) ==========
  "scm.inputFontFamily": "'Fira Code', Consolas, monospace",
  "scm.inputMinLineCount": 3,
  "scm.inputMaxLineCount": 10,
  "scm.diffDecorationsGutterWidth": 2,

  // ========== Editor ==========
  "editor.comments.insertSpace": false,
  "editor.quickSuggestions": {
    "strings": "on",
    "other": "on",
    "comments": "off",
  },
  "editor.wordWrap": "on",
  "editor.accessibilitySupport": "off",
  "editor.fontFamily": "'Fira Code', Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "expand",
  "editor.showFoldingControls": "always",
  "editor.detectIndentation": true,
  "editor.stickyScroll.enabled": true,
  "editor.hover.sticky": true,
  "editor.linkedEditing": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.foldingImportsByDefault": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.lineNumbers": "interval",
  "editor.find.addExtraSpaceOnTop": false,
  "editor.inlineSuggest.enabled": true,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "prettier.semi": false,
  "css.lint.hexColorLength": "ignore",
  "emmet.showSuggestionsAsSnippets": true,
  "emmet.triggerExpansionOnTab": false,

  // ========== Window ==========
  "window.title": "${dirty}${activeEditorShort}${separator}${rootName}",
  "window.titleBarStyle": "custom",
  "window.dialogStyle": "custom",
  "window.commandCenter": true,
  "window.customTitleBarVisibility": "auto",
  "window.menuStyle": "native",
  "window.zoomLevel": 0.025,

  // ========== Terminal ==========
  "terminal.integrated.fontFamily": "'MesloLGL Nerd Font Propo'",
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorWidth": 4,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.fontWeight": "300",
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal",
    "kilo-code.new.agentManager.runScript",
  ],

  // ========== Git ==========
  "git.autorefresh": true,
  "git.blame.ignoreWhitespace": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.fetchOnPull": true,
  "git.pruneOnFetch": true,
  "git.untrackedChanges": "separate",
  "git.openRepositoryInParentFolders": "always",

  // ========== Workbench ==========
  "workbench.iconTheme": "material-icon-theme",
  "workbench.settings.editor": "json",
  "workbench.tips.enabled": false,
  "workbench.startupEditor": "none",
  "workbench.activityBar.location": "bottom",
  "workbench.navigationControl.enabled": false,
  "workbench.layoutControl.enabled": false,
  "workbench.editor.editorActionsLocation": "titleBar",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.colorTheme": "Ayu Dark Bordered",
  "settingsSync.ignoredSettings": [],
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.labelFormat": "short",
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.colorCustomizations": {
    // The Active Tab
    "tab.activeBorderTop": "#00000000",
    "tab.activeForeground": "#5ccfe6",
    "tab.activeBackground": "#1d242c57",
    "tab.inactiveBackground": "#0f1419",
    "tab.inactiveForeground": "#5c6773",
    "editorGroupHeader.tabsBackground": "#0f1419",
    "editorGroupHeader.border": "#00000000",
    "tab.border": "#00000000",
  },

  // ========== Explorer ==========
  "explorer.compactFolders": false,
  "explorer.sortOrder": "type",
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "vite.config.*": "*.env, .babelrc*, .codecov, .cssnanorc*, .env.*, .envrc, .htmlnanorc*, .lighthouserc.*, .mocha*, .postcssrc*, .terserrc*, api-extractor.json, ava.config.*, babel.config.*, contentlayer.config.*, cssnano.config.*, cypress.*, env.d.ts, formkit.config.*, formulate.config.*, jest.config.*, jsconfig.*, karma.config.*, lighthouserc.*, playwright.config.*, postcss.config.*, puppeteer.config.*, svgo.config.*, tailwind.config.*, tsconfig.*, vitest.config.*, webpack.config.*, windi.config.*",
    "package.json": ".browserslistrc, .circleci*, .commitlintrc*, .editorconfig, .eslint*, .firebase*, .flowconfig, .github*, .gitlab*, .gitpod*, .husky*, .jslint*, .lintstagedrc*, .markdownlint*, .node-version, .npm*, .nycrc*, .prettier*, .releaserc*, .sentry*, .stackblitz*, .stylelint*, .travis*, .vscode*, .watchman*, .yamllint*, .yarnrc*, bower.json, build.config.*, commitlint*, crowdin*, dangerfile*, lerna.json, nx.json, package-lock.json, pullapprove*, pyproject.toml, release-tasks.sh, renovate*, rollup.config.*, security.md, tsconfig*, turbo.json, vercel.*, vitest.config.*, yarn.lock, app.json, eas.json, expo-env.d.ts",
  },

  // ========== Search ==========
  "search.showLineNumbers": true,
  "search.smartCase": true,
  "search.followSymlinks": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/coverage": true,
  },

  // ========== Files ==========
  "files.associations": {
    "*.css": "tailwindcss",
    "*.form": "xml",
    "app.config.js": "javascript",
    "app.json": "jsonc",
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/.expo/**": true,
  },
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ========== Extension Specific Settings ==========

  // Vite
  "vite.autoStart": true,
  "vite.open": true,

  // Indent Rainbow
  "indentRainbow.colors": ["rgba(255,255,255,0.03)", "rgba(255,255,255,0.06)"],
  "indentRainbow.errorColor": "rgba(128,0,0,0.2)",

  // Material Icon Theme
  "material-icon-theme.activeIconPack": "react",
  "material-icon-theme.folders.theme": "specific",
  "material-icon-theme.folders.color": "#6272a4",

  // Code Spell Checker
  "cSpell.language": "en,sv-SE",
  "cSpell.checkOnlyEnabledFileTypes": true,

  // Tailwind CSS
  "tailwindCSS.classAttributes": ["class", "ui", "className"],
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript",
  },
  "tailwindCSS.experimental.classRegex": [
    ["ui:\\s*{([^)]*)\\s*}", "(?:'|\\\"|`)([^']*)(?:'|\\\"|`)"],
  ],

  // AI & Chat
  "chat.viewSessions.orientation": "stacked",
  "chat.editor.fontFamily": "'Fira Code', monospace",
  "kilo-code.new.autocomplete.enableSmartInlineTaskKeybinding": false,
  "kilo-code.new.autocomplete.enableChatAutocomplete": true,

  // JS / TS
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.preferences.importModuleSpecifier": "relative",
  "js/ts.suggest.autoImports": true,
  "js/ts.preferences.preferTypeOnlyAutoImports": true,

  // ESLint
  "eslint.codeAction.showDocumentation": { "enable": true },
  "eslint.quiet": true,
  "eslint.rules.customizations": [
    { "rule": "style/*", "severity": "off" },
    { "rule": "format/*", "severity": "off" },
    { "rule": "*-indent", "severity": "off" },
    { "rule": "*-spacing", "severity": "off" },
    { "rule": "*-spaces", "severity": "off" },
    { "rule": "*-order", "severity": "off" },
    { "rule": "*-dangle", "severity": "off" },
    { "rule": "*-newline", "severity": "off" },
    { "rule": "*quotes", "severity": "off" },
    { "rule": "*semi", "severity": "off" },
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml",
    "toml",
  ],

  // Java & XML
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
  },
  "terminal.integrated.initialHint": false,
}
